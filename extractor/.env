# ─────────────────────────────────────────────────────────────────
# M2 EXTRACTOR NODE (YOGESH) ENVIRONMENT VARIABLES
# ─────────────────────────────────────────────────────────────────

# --- GPU Node Endpoints (Tailscale IPs) ---
# These are the base URLs — worker.py appends /embed/vision and /embed/text

# Rohit's Vision Node (RTX-3050)
VISION_NODE_BASE="http://100.119.250.125:8080"

# Yug's Context/Text Node (RTX-2050)
CONTEXT_NODE_BASE="http://100.115.89.72:8002"

# --- Orchestrator Webhook (Tanmay) ---
ORCHESTRATOR_WEBHOOK="http://100.69.253.89:8000/api/v1/webhooks/feeder"

# --- Authentication ---
# Secret token included in X-Webhook-Secret header for all internal cluster requests
WEBHOOK_SECRET="change-me-in-production"

# --- FFmpeg / Frame Extraction ---
FRAME_RATE="1"
JPEG_QUALITY="2"
FRAME_SIZE="224"

# --- HTTP / Retry Behavior ---
# Timeout for GPU node requests (seconds) — important for Tailscale 100.x.x.x IPs
GPU_TIMEOUT_S="60"

# Timeout for Orchestrator webhook requests (seconds)
ORCHESTRATOR_TIMEOUT="10"

# Maximum number of retries for failed frame broadcasts
MAX_FRAME_RETRIES="3"

# Initial backoff delay before retry (seconds)
BACKOFF_INITIAL_S="1.0"

# --- Heartbeat & Handshake ---
# System ping interval to Orchestrator (seconds)
PING_INTERVAL_S="30"

# Maximum time to wait for GPU nodes to drain queues after /finish signal (seconds)
GPU_IDLE_TIMEOUT_S="300"

# Poll interval for GPU idle status check (seconds)
GPU_IDLE_POLL_S="5"